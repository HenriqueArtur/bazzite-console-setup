# Modelo de configuração. Copie para .env e preencha com os SEUS valores:
#   cp .env.example .env
# O .env real está no .gitignore e nunca é commitado.

# Usuário do sistema (aparece nos caminhos /home/<USUARIO>/...)
USERNAME=seu_usuario

# Rede / Wake-on-LAN
ETHERNET_IFACE=enp4s0            # nome da interface: veja com `ip link`
ETHERNET_MAC=AA:BB:CC:DD:EE:FF   # MAC da placa Ethernet: `ip link show <IFACE>`
LOCAL_IP=192.168.0.100           # IP local do PC
BROADCAST=192.168.0.255          # broadcast da sua sub-rede
WOL_PORT=9                        # porta do magic packet (9 é o padrão)

# Bluetooth (endereços MAC dos periféricos) — veja com `bluetoothctl devices`
BT_KEYBOARD_MAC=AA:BB:CC:DD:EE:FF
BT_DS4_MAC=AA:BB:CC:DD:EE:FF
